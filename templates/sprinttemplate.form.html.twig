{% extends "generic_show_form.html.twig" %}
{% import "components/form/fields_macros.html.twig" as fields %}

{# The parent template (generic_show_form) auto-renders the standard
   `is_active` and `comment` fields. We deliberately do NOT redeclare
   them here, otherwise they show up twice and the duplicate POST input
   ends up overwriting the user's value with an empty string. #}
{% block more_fields %}

    {{ fields.textField(
        'name_pattern',
        item.fields['name_pattern'],
        __('Name pattern', 'sprint'),
        field_options|merge({
            'helper': __('e.g. Sprint {{number}} - {{project}}', 'sprint'),
        })
    ) }}

    {{ fields.dropdownNumberField(
        'duration_weeks',
        item.fields['duration_weeks'],
        __('Duration (weeks)', 'sprint'),
        field_options|merge({
            'min': 1,
            'max': 8,
        })
    ) }}

    {{ fields.textareaField(
        'goal',
        item.fields['goal'],
        __('Sprint goal', 'sprint'),
        field_options
    ) }}

{% endblock %}
