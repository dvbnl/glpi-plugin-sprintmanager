{% extends "generic_show_form.html.twig" %}
{% import "components/form/fields_macros.html.twig" as fields %}

{% block more_fields %}

    {{ fields.dropdownField(
        'GlpiPlugin\\Sprint\\Sprint',
        'plugin_sprint_sprints_id',
        item.fields['plugin_sprint_sprints_id'],
        __('Sprint', 'sprint'),
        field_options
    ) }}

    {{ fields.dropdownArrayField(
        'meeting_type',
        item.fields['meeting_type'],
        meeting_types,
        __('Type', 'sprint'),
        field_options
    ) }}

    {{ fields.datetimeField(
        'date_meeting',
        item.fields['date_meeting'],
        __('Date'),
        field_options
    ) }}

    {{ fields.dropdownNumberField(
        'duration_minutes',
        item.fields['duration_minutes'],
        __('Duration (min)', 'sprint'),
        field_options|merge({
            'min': 5,
            'max': 240,
            'step': 5,
        })
    ) }}

    {% set facilitator_name = member_options[item.fields['users_id']] is defined ? member_options[item.fields['users_id']] : '-' %}
    {{ fields.readOnlyField(
        'users_id',
        facilitator_name,
        __('Facilitator', 'sprint'),
        field_options
    ) }}

    {{ fields.textareaField(
        'notes',
        item.fields['notes'],
        __('Meeting Notes', 'sprint'),
        field_options|merge({
            'rows': 6,
        })
    ) }}

    {# Sprint Items Review — split into Fastlane + Regular #}
    {% if is_existing and sprint_items is defined %}
    {% set fastlane_items = sprint_items|filter(si => si.is_fastlane) %}
    {% set regular_items  = sprint_items|filter(si => not si.is_fastlane) %}
    {% set treated = treated_items is defined ? treated_items : [] %}
    <tr><td colspan="4" style="padding:0;">

        {# === Fastlane section === #}
        {% if fastlane_items|length > 0 %}
        <div class="mt-2 mb-0">
            <div class="d-flex align-items-center px-3 py-2" style="background:#fff3cd;font-weight:700;border-bottom:2px solid #fd7e14;border-radius:6px 6px 0 0;">
                <i class="fas fa-bolt" style="color:#fd7e14;"></i>
                <span class="ms-2">{{ __('Fastlane', 'sprint') }}</span>
                <span class="badge bg-warning text-dark ms-2">{{ fastlane_items|length }}</span>
            </div>
            <div>
                <table class="table table-striped table-hover mb-0 sprint-review-table">
                    <thead class="table-light">
                        <tr>
                            <th class="sprint-sortable" data-sort-type="treated" style="width:40px;cursor:pointer;">{{ __('Treated', 'sprint') }} <i class="fas fa-sort text-muted"></i></th>
                            <th style="width:40px;">{{ __('Type') }}</th>
                            <th>{{ __('Name') }}</th>
                            <th>{{ __('Linked item', 'sprint') }}</th>
                            <th class="sprint-sortable" data-sort-type="status" style="cursor:pointer;">{{ __('Status') }} <i class="fas fa-sort text-muted"></i></th>
                            <th class="sprint-sortable" data-sort-type="owner" style="cursor:pointer;">{{ __('Owner', 'sprint') }} <i class="fas fa-sort text-muted"></i></th>
                            <th>{{ __('Note', 'sprint') }}</th>
                            <th style="width:80px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for si in fastlane_items %}
                        {% set is_treated = si.id in treated %}
                        <tr class="sprint-review-row {{ is_treated ? 'sprint-treated' : '' }}"
                            data-item-id="{{ si.id }}"
                            data-item-name="{{ si.name }}"
                            data-item-status="{{ si.status }}"
                            data-item-priority="{{ si.priority }}"
                            data-users-id="{{ si.users_id }}"
                            data-story-points="{{ si.story_points }}"
                            data-capacity="{{ si.capacity }}"
                            data-note="{{ si.note }}">
                            <td class="text-center">
                                <input type="checkbox" name="_treated_items[]" value="{{ si.id }}"
                                       class="form-check-input sprint-treated-cb" {{ is_treated ? 'checked' : '' }}>
                            </td>
                            <td class="text-center" style="white-space:nowrap;">
                                {% if si.itemtype == 'Ticket' %}
                                    <i class="fas fa-ticket-alt" style="color:#0d6efd;" title="{{ __('Ticket') }}"></i>
                                {% elseif si.itemtype == 'Change' %}
                                    <i class="fas fa-exchange-alt" style="color:#6f42c1;" title="{{ __('Change') }}"></i>
                                {% elseif si.itemtype == 'ProjectTask' %}
                                    <i class="fas fa-tasks" style="color:#fd7e14;" title="{{ __('Project task') }}"></i>
                                {% else %}
                                    <i class="fas fa-clipboard-list" style="color:#6c757d;" title="{{ __('Manual', 'sprint') }}"></i>
                                {% endif %}
                            </td>
                            <td>
                                <i class="fas fa-bolt" style="color:#fd7e14;margin-right:4px;"></i>
                                <a href="{{ si.url }}">{{ si.name }}</a>
                            </td>
                            <td>{{ si.linked_display|raw }}</td>
                            <td>
                                <select name="_sprintitems[{{ si.id }}][status]" class="form-select form-select-sm sprint-review-field" style="width:auto;min-width:120px;" {{ is_treated ? 'disabled' : '' }}>
                                    {% for key, label in item_statuses %}
                                    <option value="{{ key }}" {{ si.status == key ? 'selected' : '' }}>{{ label }}</option>
                                    {% endfor %}
                                </select>
                            </td>
                            <td>
                                <select name="_sprintitems[{{ si.id }}][users_id]" class="form-select form-select-sm sprint-review-field" style="width:auto;min-width:140px;" {{ is_treated ? 'disabled' : '' }}>
                                    {% for uid, uname in member_options %}
                                    <option value="{{ uid }}" {{ si.users_id == uid ? 'selected' : '' }}>{{ uname }}</option>
                                    {% endfor %}
                                </select>
                            </td>
                            <td>
                                <input type="text" name="_sprintitems[{{ si.id }}][note]" value="{{ si.note }}"
                                       class="form-control form-control-sm sprint-review-field"
                                       placeholder="{{ __('Add note...', 'sprint') }}" style="min-width:180px;"
                                       {{ is_treated ? 'disabled' : '' }}>
                            </td>
                            <td class="text-center" style="white-space:nowrap;">
                                <button type="button"
                                        class="btn btn-sm btn-outline-primary sprint-quick-edit-btn me-1"
                                        title="{{ __('Quick edit', 'sprint') }}"
                                        data-item-id="{{ si.id }}">
                                    <i class="fas fa-pen"></i>
                                </button>
                                <button type="button"
                                        class="btn btn-sm btn-outline-warning sprint-backlog-btn"
                                        title="{{ __('Back to backlog', 'sprint') }}"
                                        data-backlog-id="{{ si.id }}"
                                        {{ is_treated ? 'disabled' : '' }}>
                                    <i class="fas fa-undo"></i>
                                </button>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        {% endif %}

        {# === Regular sprint items section === #}
        <div class="{{ fastlane_items|length > 0 ? 'mt-3' : 'mt-2' }} mb-2">
            <div class="d-flex align-items-center px-3 py-2" style="background:#f8f9fa;font-weight:700;border-radius:6px 6px 0 0;">
                <i class="fas fa-clipboard-list"></i>
                <span class="ms-2">{{ __('Sprint Items Review', 'sprint') }}</span>
                <span class="badge bg-secondary ms-2">{{ regular_items|length }}</span>
            </div>
            <div>
                {% if regular_items|length > 0 %}
                <table class="table table-striped table-hover mb-0 sprint-review-table">
                    <thead class="table-light">
                        <tr>
                            <th class="sprint-sortable" data-sort-type="treated" style="width:40px;cursor:pointer;">{{ __('Treated', 'sprint') }} <i class="fas fa-sort text-muted"></i></th>
                            <th style="width:40px;">{{ __('Type') }}</th>
                            <th>{{ __('Name') }}</th>
                            <th>{{ __('Linked item', 'sprint') }}</th>
                            <th class="sprint-sortable" data-sort-type="status" style="cursor:pointer;">{{ __('Status') }} <i class="fas fa-sort text-muted"></i></th>
                            <th class="sprint-sortable" data-sort-type="owner" style="cursor:pointer;">{{ __('Owner', 'sprint') }} <i class="fas fa-sort text-muted"></i></th>
                            <th>{{ __('Note', 'sprint') }}</th>
                            <th style="width:80px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for si in regular_items %}
                        {% set is_treated = si.id in treated %}
                        <tr class="sprint-review-row {{ is_treated ? 'sprint-treated' : '' }}"
                            data-item-id="{{ si.id }}"
                            data-item-name="{{ si.name }}"
                            data-item-status="{{ si.status }}"
                            data-item-priority="{{ si.priority }}"
                            data-users-id="{{ si.users_id }}"
                            data-story-points="{{ si.story_points }}"
                            data-capacity="{{ si.capacity }}"
                            data-note="{{ si.note }}">
                            <td class="text-center">
                                <input type="checkbox" name="_treated_items[]" value="{{ si.id }}"
                                       class="form-check-input sprint-treated-cb" {{ is_treated ? 'checked' : '' }}>
                            </td>
                            <td class="text-center" style="white-space:nowrap;">
                                {% if si.itemtype == 'Ticket' %}
                                    <i class="fas fa-ticket-alt" style="color:#0d6efd;" title="{{ __('Ticket') }}"></i>
                                {% elseif si.itemtype == 'Change' %}
                                    <i class="fas fa-exchange-alt" style="color:#6f42c1;" title="{{ __('Change') }}"></i>
                                {% elseif si.itemtype == 'ProjectTask' %}
                                    <i class="fas fa-tasks" style="color:#fd7e14;" title="{{ __('Project task') }}"></i>
                                {% else %}
                                    <i class="fas fa-clipboard-list" style="color:#6c757d;" title="{{ __('Manual', 'sprint') }}"></i>
                                {% endif %}
                            </td>
                            <td><a href="{{ si.url }}">{{ si.name }}</a></td>
                            <td>{{ si.linked_display|raw }}</td>
                            <td>
                                <select name="_sprintitems[{{ si.id }}][status]" class="form-select form-select-sm sprint-review-field" style="width:auto;min-width:120px;" {{ is_treated ? 'disabled' : '' }}>
                                    {% for key, label in item_statuses %}
                                    <option value="{{ key }}" {{ si.status == key ? 'selected' : '' }}>{{ label }}</option>
                                    {% endfor %}
                                </select>
                            </td>
                            <td>
                                <select name="_sprintitems[{{ si.id }}][users_id]" class="form-select form-select-sm sprint-review-field" style="width:auto;min-width:140px;" {{ is_treated ? 'disabled' : '' }}>
                                    {% for uid, uname in member_options %}
                                    <option value="{{ uid }}" {{ si.users_id == uid ? 'selected' : '' }}>{{ uname }}</option>
                                    {% endfor %}
                                </select>
                            </td>
                            <td>
                                <input type="text" name="_sprintitems[{{ si.id }}][note]" value="{{ si.note }}"
                                       class="form-control form-control-sm sprint-review-field"
                                       placeholder="{{ __('Add note...', 'sprint') }}" style="min-width:180px;"
                                       {{ is_treated ? 'disabled' : '' }}>
                            </td>
                            <td class="text-center" style="white-space:nowrap;">
                                <button type="button"
                                        class="btn btn-sm btn-outline-primary sprint-quick-edit-btn me-1"
                                        title="{{ __('Quick edit', 'sprint') }}"
                                        data-item-id="{{ si.id }}">
                                    <i class="fas fa-pen"></i>
                                </button>
                                <button type="button"
                                        class="btn btn-sm btn-outline-warning sprint-backlog-btn"
                                        title="{{ __('Back to backlog', 'sprint') }}"
                                        data-backlog-id="{{ si.id }}"
                                        {{ is_treated ? 'disabled' : '' }}>
                                    <i class="fas fa-undo"></i>
                                </button>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>

                {% else %}
                <div class="text-center text-muted py-3">
                    <i class="fas fa-inbox" style="font-size:1.5em;"></i><br>
                    {{ __('No items in this sprint', 'sprint') }}
                </div>
                {% endif %}
            </div>
        </div>

        <script>
        $(function() {
            // Toggle treated state: grey out row + disable fields
            $(document).on('change', '.sprint-treated-cb', function() {
                var row = $(this).closest('tr');
                var fields = row.find('.sprint-review-field');
                var backlogBtn = row.find('.sprint-backlog-btn');
                if (this.checked) {
                    row.addClass('sprint-treated');
                    fields.prop('disabled', true);
                    backlogBtn.prop('disabled', true);
                } else {
                    row.removeClass('sprint-treated');
                    fields.prop('disabled', false);
                    backlogBtn.prop('disabled', false);
                }
            });

            // Back to backlog: create a standalone form outside the parent meeting form and submit it
            $(document).on('click', '.sprint-backlog-btn', function() {
                var itemId = $(this).data('backlog-id');
                if (!confirm('{{ __('Move this item back to the backlog?', 'sprint') }}')) {
                    return;
                }
                var f = $('<form method="post" action="{{ backlog_url }}" style="display:none;"></form>');
                f.append('<input type="hidden" name="id" value="' + itemId + '">');
                f.append('<input type="hidden" name="back_to_backlog" value="1">');
                f.append('<input type="hidden" name="_redirect" value="{{ meeting_url }}">');
                f.append('<input type="hidden" name="_glpi_csrf_token" value="' + $('input[name=_glpi_csrf_token]').first().val() + '">');
                $('body').append(f);
                f.submit();
            });

            // Before form submit: re-enable disabled fields so they get posted
            $('form').on('submit', function() {
                $(this).find('.sprint-treated .sprint-review-field').prop('disabled', false);
                $(this).find('.sprint-treated').each(function() {
                    var id = $(this).data('item-id');
                    if (!$(this).find('input[name="_sprintitems[' + id + '][_treated]"]').length) {
                        $(this).append('<input type="hidden" name="_sprintitems[' + id + '][_treated]" value="1">');
                    }
                });
            });

            // === Quick-edit modal ===
            // Move the modal out of the meeting <form> so nested forms don't break validation.
            var $modal = $('#sprint-quickedit-modal').detach().appendTo('body');

            $(document).on('click', '.sprint-quick-edit-btn', function() {
                var $row     = $(this).closest('tr');
                var itemId   = $row.data('item-id');
                var itemName = $row.data('item-name') || '';
                var status   = $row.data('item-status') || '';
                var priority = $row.data('item-priority') || 3;
                var usersId  = $row.data('users-id') || 0;
                var points   = $row.data('story-points') || 0;
                var capacity = $row.data('capacity') || 0;
                var note     = $row.data('note') || '';

                $modal.find('.sprint-qe-title').text(itemName);
                $modal.find('input[name=id]').val(itemId);
                $modal.find('input[name=name]').val(itemName);
                $modal.find('select[name=status]').val(String(status));
                $modal.find('select[name=priority]').val(String(priority));
                $modal.find('select[name=users_id]').val(String(usersId));
                $modal.find('input[name=story_points]').val(points);
                $modal.find('select[name=capacity]').val(String(capacity));
                $modal.find('textarea[name=note]').val(note);
                $modal.find('.sprint-qe-error').hide().text('');

                var m = new bootstrap.Modal($modal[0]);
                m.show();
                $modal.data('bs-instance', m);
            });

            $(document).on('click', '.sprint-qe-save', function() {
                var $btn = $(this);
                var id = $modal.find('input[name=id]').val();

                $btn.prop('disabled', true);
                $modal.find('.sprint-qe-error').hide().text('');

                // GLPI 11 CSRF tokens are single-use — fetch a fresh one per save.
                $.ajax({
                    url: CFG_GLPI.root_doc + '/plugins/sprint/ajax/csrftoken.php',
                    type: 'GET',
                    dataType: 'json',
                    cache: false
                }).then(function(tokResp) {
                    return $.ajax({
                        url: CFG_GLPI.root_doc + '/plugins/sprint/ajax/updateitemquick.php',
                        type: 'POST',
                        dataType: 'json',
                        data: {
                            id:           id,
                            name:         $modal.find('input[name=name]').val(),
                            status:       $modal.find('select[name=status]').val(),
                            priority:     $modal.find('select[name=priority]').val(),
                            users_id:     $modal.find('select[name=users_id]').val(),
                            story_points: $modal.find('input[name=story_points]').val(),
                            capacity:     $modal.find('select[name=capacity]').val(),
                            note:         $modal.find('textarea[name=note]').val(),
                            _glpi_csrf_token: tokResp && tokResp.token ? tokResp.token : ''
                        }
                    });
                }).done(function(resp) {
                    if (resp && resp.success) {
                        var $row = $('tr.sprint-review-row[data-item-id="' + id + '"]');
                        // Sync row data attributes so subsequent edits start from fresh values
                        $row.attr('data-item-name', resp.name).data('item-name', resp.name);
                        $row.attr('data-item-status', resp.status).data('item-status', resp.status);
                        $row.attr('data-item-priority', resp.priority).data('item-priority', resp.priority);
                        $row.attr('data-users-id', resp.users_id).data('users-id', resp.users_id);
                        $row.attr('data-story-points', resp.story_points).data('story-points', resp.story_points);
                        $row.attr('data-capacity', resp.capacity).data('capacity', resp.capacity);
                        $row.attr('data-note', resp.note).data('note', resp.note);
                        // Sync inline controls so the meeting form posts the same values
                        $row.find('select[name="_sprintitems[' + id + '][status]"]').val(String(resp.status));
                        $row.find('select[name="_sprintitems[' + id + '][users_id]"]').val(String(resp.users_id));
                        $row.find('input[name="_sprintitems[' + id + '][note]"]').val(resp.note);
                        // Update the visible item name link if present
                        $row.find('td a').filter(function() {
                            return $(this).attr('href') && $(this).attr('href').indexOf('sprintitem.form.php') !== -1;
                        }).text(resp.name);
                        var m = $modal.data('bs-instance');
                        if (m) { m.hide(); }
                    } else {
                        $modal.find('.sprint-qe-error').text(resp && resp.message ? resp.message : 'Save failed').show();
                    }
                }).fail(function() {
                    $modal.find('.sprint-qe-error').text('Network error').show();
                }).always(function() {
                    $btn.prop('disabled', false);
                });
            });

            // === Column sorting ===
            var sortState = {}; // key: table+type → 'asc'|'desc'

            function rowSortValue($row, type) {
                if (type === 'treated') {
                    return $row.find('.sprint-treated-cb').is(':checked') ? 1 : 0;
                }
                if (type === 'status') {
                    var $sel = $row.find('select[name$="[status]"]');
                    var opt = $sel.find('option:selected');
                    return (opt.text() || $sel.val() || '').toLowerCase();
                }
                if (type === 'owner') {
                    var $osel = $row.find('select[name$="[users_id]"]');
                    var oopt = $osel.find('option:selected');
                    return (oopt.text() || '').toLowerCase();
                }
                return '';
            }

            $(document).on('click', '.sprint-sortable', function() {
                var $th = $(this);
                var type = $th.data('sort-type');
                var $table = $th.closest('table');
                var $tbody = $table.find('tbody');
                var tableId = $table.index('.sprint-review-table');
                var key = tableId + ':' + type;
                var dir = sortState[key] === 'asc' ? 'desc' : 'asc';
                sortState[key] = dir;

                // Reset icons in this table
                $table.find('.sprint-sortable i').removeClass('fa-sort-up fa-sort-down').addClass('fa-sort').addClass('text-muted');
                $th.find('i').removeClass('fa-sort text-muted').addClass(dir === 'asc' ? 'fa-sort-up' : 'fa-sort-down');

                var rows = $tbody.find('tr.sprint-review-row').get();
                rows.sort(function(a, b) {
                    var av = rowSortValue($(a), type);
                    var bv = rowSortValue($(b), type);
                    if (av < bv) { return dir === 'asc' ? -1 : 1; }
                    if (av > bv) { return dir === 'asc' ? 1 : -1; }
                    return 0;
                });
                $.each(rows, function(i, row) { $tbody.append(row); });
            });
        });
        </script>

        {# Quick-edit modal — rendered once, moved out of the form by JS #}
        <div class="modal fade" id="sprint-quickedit-modal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">
                            <i class="fas fa-pen me-1"></i>
                            {{ __('Quick edit', 'sprint') }}: <span class="sprint-qe-title"></span>
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="alert alert-danger sprint-qe-error" style="display:none;white-space:pre-line;"></div>
                        <input type="hidden" name="id" value="">

                        <div class="mb-3">
                            <label class="form-label">{{ __('Name') }}</label>
                            <input type="text" name="name" class="form-control" value="">
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">{{ __('Status') }}</label>
                                <select name="status" class="form-select">
                                    {% for key, label in item_statuses %}
                                    <option value="{{ key }}">{{ label }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">{{ __('Priority') }}</label>
                                <select name="priority" class="form-select">
                                    {% for key, label in item_priorities %}
                                    <option value="{{ key }}">{{ label }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">{{ __('Owner', 'sprint') }}</label>
                                <select name="users_id" class="form-select">
                                    {% for uid, uname in member_options %}
                                    <option value="{{ uid }}">{{ uname }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="col-md-3 mb-3">
                                <label class="form-label">{{ __('Story Points', 'sprint') }}</label>
                                <input type="number" name="story_points" class="form-control" min="0" step="1" value="0">
                            </div>
                            <div class="col-md-3 mb-3">
                                <label class="form-label">{{ __('Capacity (%)', 'sprint') }}</label>
                                <select name="capacity" class="form-select">
                                    {% for val, label in capacity_choices %}
                                    <option value="{{ val }}">{{ label }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">{{ __('Note', 'sprint') }}</label>
                            <textarea name="note" class="form-control" rows="3"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ __('Cancel') }}</button>
                        <button type="button" class="btn btn-primary sprint-qe-save">
                            <i class="fas fa-save me-1"></i> {{ __('Save') }}
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <style>
        .sprint-treated td { opacity: 0.45; }
        .sprint-treated td:first-child { opacity: 1; }
        </style>

    </td></tr>
    {% endif %}

{% endblock %}
