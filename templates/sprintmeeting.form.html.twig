{% extends "generic_show_form.html.twig" %}
{% import "components/form/fields_macros.html.twig" as fields %}

{% block more_fields %}

    {{ fields.dropdownField(
        'GlpiPlugin\\Sprint\\Sprint',
        'plugin_sprint_sprints_id',
        item.fields['plugin_sprint_sprints_id'],
        __('Sprint', 'sprint'),
        field_options
    ) }}

    {{ fields.dropdownArrayField(
        'meeting_type',
        item.fields['meeting_type'],
        meeting_types,
        __('Type', 'sprint'),
        field_options
    ) }}

    {{ fields.datetimeField(
        'date_meeting',
        item.fields['date_meeting'],
        __('Date'),
        field_options
    ) }}

    {{ fields.dropdownNumberField(
        'duration_minutes',
        item.fields['duration_minutes'],
        __('Duration (min)', 'sprint'),
        field_options|merge({
            'min': 5,
            'max': 240,
            'step': 5,
        })
    ) }}

    {% set facilitator_name = member_options[item.fields['users_id']] is defined ? member_options[item.fields['users_id']] : '-' %}
    {{ fields.readOnlyField(
        'users_id',
        facilitator_name,
        __('Facilitator', 'sprint'),
        field_options
    ) }}

    {{ fields.textareaField(
        'notes',
        item.fields['notes'],
        __('Meeting Notes', 'sprint'),
        field_options|merge({
            'rows': 6,
        })
    ) }}

    {# Sprint Items Review — split into Fastlane + Regular #}
    {% if is_existing and sprint_items is defined %}
    {% set fastlane_items = sprint_items|filter(si => si.is_fastlane) %}
    {% set regular_items  = sprint_items|filter(si => not si.is_fastlane) %}

    {% set status_bg = {
        'todo':        '#6c757d',
        'in_progress': '#0d6efd',
        'review':      '#6f42c1',
        'done':        '#198754',
        'blocked':     '#dc3545',
    } %}

    <tr><td colspan="4" style="padding:0;">

        {# === Fastlane section === #}
        {% if fastlane_items|length > 0 %}
        <div class="mt-2 mb-0">
            <div class="d-flex align-items-center px-3 py-2" style="background:#fff3cd;font-weight:700;border-bottom:2px solid #fd7e14;border-radius:6px 6px 0 0;">
                <i class="fas fa-bolt" style="color:#fd7e14;"></i>
                <span class="ms-2">{{ __('Fastlane', 'sprint') }}</span>
                <span class="badge bg-warning text-dark ms-2">{{ fastlane_items|length }}</span>
            </div>
            <div id="sprint-filter-fastlane" class="sprint-filter-bar d-flex flex-wrap align-items-center gap-2 p-2 mb-2"
                 data-target="sprint-review-fastlane" style="background:#f1f3f5;border-radius:6px;">
                <div class="d-flex align-items-center gap-1 text-muted small">
                    <i class="fas fa-filter"></i><span>{{ __('Filter', 'sprint') }}</span>
                </div>
                <input type="search" class="form-control form-control-sm sf-text" style="max-width:220px;"
                       placeholder="{{ __('Search name...', 'sprint') }}">
                <select class="form-select form-select-sm sf-status" style="max-width:180px;">
                    <option value="">{{ __('All statuses', 'sprint') }}</option>
                    <option value="__not_done__">{{ __('Not done', 'sprint') }}</option>
                    {% for key, label in item_statuses %}
                    <option value="{{ key }}">{{ label }}</option>
                    {% endfor %}
                </select>
                <select class="form-select form-select-sm sf-owner" style="max-width:220px;">
                    <option value="">{{ __('All owners', 'sprint') }}</option>
                    <option value="__unassigned__">{{ __('Unassigned only', 'sprint') }}</option>
                    {% for uid, uname in member_options %}
                    {% if uid > 0 %}
                    <option value="{{ uid }}">{{ uname }}</option>
                    {% endif %}
                    {% endfor %}
                </select>
                <button type="button" class="btn btn-sm btn-outline-secondary sf-reset" data-sprint-action="filter-reset">
                    <i class="fas fa-times me-1"></i>{{ __('Reset', 'sprint') }}
                </button>
            </div>
            <div>
                <table class="table table-striped table-hover mb-0 sprint-review-table sprint-review-fastlane">
                    <thead class="table-light">
                        <tr>
                            <th style="width:40px;">{{ __('Type') }}</th>
                            <th class="sprint-sortable" data-sort-type="name" data-sprint-action="sort" style="cursor:pointer;">{{ __('Name') }} <i class="fas fa-sort text-muted"></i></th>
                            <th>{{ __('Linked item', 'sprint') }}</th>
                            <th class="sprint-sortable" data-sort-type="status" data-sprint-action="sort" style="cursor:pointer;">{{ __('Status') }} <i class="fas fa-sort text-muted"></i></th>
                            <th class="sprint-sortable" data-sort-type="owner" data-sprint-action="sort" style="cursor:pointer;">{{ __('Owner', 'sprint') }} <i class="fas fa-sort text-muted"></i></th>
                            <th style="min-width:220px;">{{ __('Note', 'sprint') }}</th>
                            <th style="width:80px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for si in fastlane_items %}
                        {% set owner_name = member_options[si.users_id] is defined ? member_options[si.users_id] : '' %}
                        {% set status_label = item_statuses[si.status] is defined ? item_statuses[si.status] : si.status %}
                        {% set status_color = status_bg[si.status] is defined ? status_bg[si.status] : '#6c757d' %}
                        <tr class="sprint-review-row sprint-filterable-row"
                            data-item-id="{{ si.id }}"
                            data-item-name="{{ si.name }}"
                            data-item-status="{{ si.status }}"
                            data-item-status-label="{{ status_label }}"
                            data-item-priority="{{ si.priority }}"
                            data-users-id="{{ si.users_id }}"
                            data-owner-name="{{ owner_name }}"
                            data-story-points="{{ si.story_points }}"
                            data-capacity="{{ si.capacity }}"
                            data-is-fastlane="1"
                            data-note="{{ si.note }}"
                            data-fastlane-url="{{ si.fastlane_url }}"
                            data-fastlane-allocations="{{ si.fastlane_allocations|default([])|json_encode|e('html_attr') }}">
                            <td class="text-center" style="white-space:nowrap;">
                                {% if si.itemtype == 'Ticket' %}
                                    <i class="fas fa-ticket-alt" style="color:#0d6efd;" title="{{ __('Ticket') }}"></i>
                                {% elseif si.itemtype == 'Change' %}
                                    <i class="fas fa-exchange-alt" style="color:#6f42c1;" title="{{ __('Change') }}"></i>
                                {% elseif si.itemtype == 'ProjectTask' %}
                                    <i class="fas fa-tasks" style="color:#fd7e14;" title="{{ __('Project task') }}"></i>
                                {% else %}
                                    <i class="fas fa-clipboard-list" style="color:#6c757d;" title="{{ __('Manual', 'sprint') }}"></i>
                                {% endif %}
                            </td>
                            <td>
                                <i class="fas fa-bolt" style="color:#fd7e14;margin-right:4px;"></i>
                                <a href="{{ si.url }}">{{ si.name }}</a>
                            </td>
                            <td>{{ si.linked_display|raw }}</td>
                            <td>
                                <span class="sprint-badge sprint-review-status" style="display:inline-block;padding:4px 12px;border-radius:20px;font-size:0.8em;font-weight:600;color:#fff;background-color:{{ status_color }};">
                                    {{ status_label }}
                                </span>
                            </td>
                            <td class="sprint-review-owner">
                                {% if si.fastlane_allocations is defined and si.fastlane_allocations|length > 0 %}
                                    <div style="display:flex;flex-direction:column;gap:2px;">
                                        {% for alloc in si.fastlane_allocations %}
                                            <div style="font-size:0.88em;line-height:1.3;">
                                                <i class="fas fa-bolt text-warning me-1" style="font-size:0.78em;"></i>{{ alloc.name }}
                                                <span class="text-muted">({{ alloc.capacity }}%)</span>
                                            </div>
                                        {% endfor %}
                                        {% if si.fastlane_total is defined and si.fastlane_total > 0 %}
                                            <div class="text-muted" style="font-size:0.78em;margin-top:2px;">
                                                {{ __('Total', 'sprint') }}: <strong style="color:#fd7e14;">{{ si.fastlane_total }}%</strong>
                                            </div>
                                        {% endif %}
                                    </div>
                                {% else %}
                                    <span class="text-muted fst-italic">{{ __('No allocations', 'sprint') }}</span>
                                    <a href="{{ si.fastlane_url }}" class="ms-1" title="{{ __('Manage fastlane members', 'sprint') }}">
                                        <i class="fas fa-cog text-muted"></i>
                                    </a>
                                {% endif %}
                            </td>
                            <td class="sprint-review-note" style="max-width:360px;">
                                <div class="sprint-note-display" style="white-space:pre-wrap;word-break:break-word;min-height:38px;max-height:120px;overflow:auto;padding:6px 8px;background:#f8f9fa;border:1px solid #e9ecef;border-radius:4px;font-size:0.88em;color:#495057;">{{ si.note }}</div>
                            </td>
                            <td class="text-center" style="white-space:nowrap;">
                                <button type="button"
                                        class="btn btn-sm btn-outline-primary sprint-quick-edit-btn me-1"
                                        title="{{ __('Quick edit', 'sprint') }}"
                                        data-item-id="{{ si.id }}">
                                    <i class="fas fa-pen"></i>
                                </button>
                                <a href="{{ si.fastlane_url }}"
                                   class="btn btn-sm btn-outline-warning me-1"
                                   title="{{ __('Manage fastlane members', 'sprint') }}">
                                    <i class="fas fa-users"></i>
                                </a>
                                {% if move_target_sprints is defined and move_target_sprints|length > 0 %}
                                <div class="dropdown d-inline-block me-1">
                                    <button type="button"
                                            class="btn btn-sm btn-outline-success dropdown-toggle"
                                            data-bs-toggle="dropdown"
                                            aria-expanded="false"
                                            title="{{ __('Carry over to another sprint', 'sprint') }}">
                                        <i class="fas fa-forward"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li><h6 class="dropdown-header">{{ __('Carry over to sprint', 'sprint') }}</h6></li>
                                        {% for target_id, target_label in move_target_sprints %}
                                        <li>
                                            <a href="#" class="dropdown-item sprint-carry-over-btn"
                                               data-item-id="{{ si.id }}"
                                               data-sprint-id="{{ target_id }}"
                                               data-sprint-label="{{ target_label }}">
                                                <i class="fas fa-forward text-muted me-1"></i>{{ target_label }}
                                            </a>
                                        </li>
                                        {% endfor %}
                                    </ul>
                                </div>
                                {% endif %}
                                <button type="button"
                                        class="btn btn-sm btn-outline-warning sprint-backlog-btn"
                                        title="{{ __('Back to backlog', 'sprint') }}"
                                        data-backlog-id="{{ si.id }}">
                                    <i class="fas fa-undo"></i>
                                </button>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        {% endif %}

        {# === Regular sprint items section === #}
        <div class="{{ fastlane_items|length > 0 ? 'mt-3' : 'mt-2' }} mb-2">
            <div class="d-flex align-items-center px-3 py-2" style="background:#f8f9fa;font-weight:700;border-radius:6px 6px 0 0;">
                <i class="fas fa-clipboard-list"></i>
                <span class="ms-2">{{ __('Sprint Items Review', 'sprint') }}</span>
                <span class="badge bg-secondary ms-2">{{ regular_items|length }}</span>
            </div>
            {% if regular_items|length > 0 %}
            <div id="sprint-filter-regular" class="sprint-filter-bar d-flex flex-wrap align-items-center gap-2 p-2 mb-2"
                 data-target="sprint-review-regular" style="background:#f1f3f5;border-radius:6px;">
                <div class="d-flex align-items-center gap-1 text-muted small">
                    <i class="fas fa-filter"></i><span>{{ __('Filter', 'sprint') }}</span>
                </div>
                <input type="search" class="form-control form-control-sm sf-text" style="max-width:220px;"
                       placeholder="{{ __('Search name...', 'sprint') }}">
                <select class="form-select form-select-sm sf-status" style="max-width:180px;">
                    <option value="">{{ __('All statuses', 'sprint') }}</option>
                    <option value="__not_done__">{{ __('Not done', 'sprint') }}</option>
                    {% for key, label in item_statuses %}
                    <option value="{{ key }}">{{ label }}</option>
                    {% endfor %}
                </select>
                <select class="form-select form-select-sm sf-owner" style="max-width:220px;">
                    <option value="">{{ __('All owners', 'sprint') }}</option>
                    <option value="__unassigned__">{{ __('Unassigned only', 'sprint') }}</option>
                    {% for uid, uname in member_options %}
                    {% if uid > 0 %}
                    <option value="{{ uid }}">{{ uname }}</option>
                    {% endif %}
                    {% endfor %}
                </select>
                <button type="button" class="btn btn-sm btn-outline-secondary sf-reset" data-sprint-action="filter-reset">
                    <i class="fas fa-times me-1"></i>{{ __('Reset', 'sprint') }}
                </button>
            </div>
            <div>
                <table class="table table-striped table-hover mb-0 sprint-review-table sprint-review-regular">
                    <thead class="table-light">
                        <tr>
                            <th style="width:40px;">{{ __('Type') }}</th>
                            <th class="sprint-sortable" data-sort-type="name" data-sprint-action="sort" style="cursor:pointer;">{{ __('Name') }} <i class="fas fa-sort text-muted"></i></th>
                            <th>{{ __('Linked item', 'sprint') }}</th>
                            <th class="sprint-sortable" data-sort-type="status" data-sprint-action="sort" style="cursor:pointer;">{{ __('Status') }} <i class="fas fa-sort text-muted"></i></th>
                            <th class="sprint-sortable" data-sort-type="owner" data-sprint-action="sort" style="cursor:pointer;">{{ __('Owner', 'sprint') }} <i class="fas fa-sort text-muted"></i></th>
                            <th style="min-width:220px;">{{ __('Note', 'sprint') }}</th>
                            <th style="width:80px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for si in regular_items %}
                        {% set owner_name = member_options[si.users_id] is defined ? member_options[si.users_id] : '' %}
                        {% set status_label = item_statuses[si.status] is defined ? item_statuses[si.status] : si.status %}
                        {% set status_color = status_bg[si.status] is defined ? status_bg[si.status] : '#6c757d' %}
                        <tr class="sprint-review-row sprint-filterable-row"
                            data-item-id="{{ si.id }}"
                            data-item-name="{{ si.name }}"
                            data-item-status="{{ si.status }}"
                            data-item-status-label="{{ status_label }}"
                            data-item-priority="{{ si.priority }}"
                            data-users-id="{{ si.users_id }}"
                            data-owner-name="{{ owner_name }}"
                            data-story-points="{{ si.story_points }}"
                            data-capacity="{{ si.capacity }}"
                            data-is-fastlane="0"
                            data-note="{{ si.note }}">
                            <td class="text-center" style="white-space:nowrap;">
                                {% if si.itemtype == 'Ticket' %}
                                    <i class="fas fa-ticket-alt" style="color:#0d6efd;" title="{{ __('Ticket') }}"></i>
                                {% elseif si.itemtype == 'Change' %}
                                    <i class="fas fa-exchange-alt" style="color:#6f42c1;" title="{{ __('Change') }}"></i>
                                {% elseif si.itemtype == 'ProjectTask' %}
                                    <i class="fas fa-tasks" style="color:#fd7e14;" title="{{ __('Project task') }}"></i>
                                {% else %}
                                    <i class="fas fa-clipboard-list" style="color:#6c757d;" title="{{ __('Manual', 'sprint') }}"></i>
                                {% endif %}
                            </td>
                            <td><a href="{{ si.url }}">{{ si.name }}</a></td>
                            <td>{{ si.linked_display|raw }}</td>
                            <td>
                                <span class="sprint-badge sprint-review-status" style="display:inline-block;padding:4px 12px;border-radius:20px;font-size:0.8em;font-weight:600;color:#fff;background-color:{{ status_color }};">
                                    {{ status_label }}
                                </span>
                            </td>
                            <td class="sprint-review-owner">
                                {% if owner_name != '' %}
                                    <i class="fas fa-user text-muted me-1"></i>{{ owner_name }}
                                {% else %}
                                    <span class="text-muted fst-italic">{{ __('Unassigned', 'sprint') }}</span>
                                {% endif %}
                            </td>
                            <td class="sprint-review-note" style="max-width:360px;">
                                <div class="sprint-note-display" style="white-space:pre-wrap;word-break:break-word;min-height:38px;max-height:120px;overflow:auto;padding:6px 8px;background:#f8f9fa;border:1px solid #e9ecef;border-radius:4px;font-size:0.88em;color:#495057;">{{ si.note }}</div>
                            </td>
                            <td class="text-center" style="white-space:nowrap;">
                                <button type="button"
                                        class="btn btn-sm btn-outline-primary sprint-quick-edit-btn me-1"
                                        title="{{ __('Quick edit', 'sprint') }}"
                                        data-item-id="{{ si.id }}">
                                    <i class="fas fa-pen"></i>
                                </button>
                                {% if move_target_sprints is defined and move_target_sprints|length > 0 %}
                                <div class="dropdown d-inline-block me-1">
                                    <button type="button"
                                            class="btn btn-sm btn-outline-success dropdown-toggle"
                                            data-bs-toggle="dropdown"
                                            aria-expanded="false"
                                            title="{{ __('Carry over to another sprint', 'sprint') }}">
                                        <i class="fas fa-forward"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li><h6 class="dropdown-header">{{ __('Carry over to sprint', 'sprint') }}</h6></li>
                                        {% for target_id, target_label in move_target_sprints %}
                                        <li>
                                            <a href="#" class="dropdown-item sprint-carry-over-btn"
                                               data-item-id="{{ si.id }}"
                                               data-sprint-id="{{ target_id }}"
                                               data-sprint-label="{{ target_label }}">
                                                <i class="fas fa-forward text-muted me-1"></i>{{ target_label }}
                                            </a>
                                        </li>
                                        {% endfor %}
                                    </ul>
                                </div>
                                {% endif %}
                                <button type="button"
                                        class="btn btn-sm btn-outline-warning sprint-backlog-btn"
                                        title="{{ __('Back to backlog', 'sprint') }}"
                                        data-backlog-id="{{ si.id }}">
                                    <i class="fas fa-undo"></i>
                                </button>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% else %}
            <div class="text-center text-muted py-3">
                <i class="fas fa-inbox" style="font-size:1.5em;"></i><br>
                {{ __('No items in this sprint', 'sprint') }}
            </div>
            {% endif %}
        </div>

        <script>
        $(function() {
            var statusColors = {
                'todo':        '#6c757d',
                'in_progress': '#0d6efd',
                'review':      '#6f42c1',
                'done':        '#198754',
                'blocked':     '#dc3545'
            };

            // Back to backlog: create a standalone form outside the parent meeting form and submit it
            $(document).on('click', '.sprint-backlog-btn', function() {
                var itemId = $(this).data('backlog-id');
                if (!confirm('{{ __('Move this item back to the backlog?', 'sprint') }}')) {
                    return;
                }
                var f = $('<form method="post" action="{{ backlog_url }}" style="display:none;"></form>');
                f.append('<input type="hidden" name="id" value="' + itemId + '">');
                f.append('<input type="hidden" name="back_to_backlog" value="1">');
                f.append('<input type="hidden" name="_redirect" value="{{ meeting_url }}">');
                f.append('<input type="hidden" name="_glpi_csrf_token" value="' + $('input[name=_glpi_csrf_token]').first().val() + '">');
                $('body').append(f);
                f.submit();
            });

            $(document).on('click', '.sprint-carry-over-btn', function(e) {
                e.preventDefault();
                var $btn = $(this);
                var itemId    = $btn.data('item-id');
                var sprintId  = $btn.data('sprint-id');
                var sprintLbl = $btn.data('sprint-label') || '';
                var msg = '{{ __('Carry this item over to: %s ? The original stays in the current sprint.', 'sprint') }}'.replace('%s', sprintLbl);
                if (!confirm(msg)) {
                    return;
                }
                var f = $('<form method="post" action="{{ backlog_url }}" style="display:none;"></form>');
                f.append('<input type="hidden" name="id" value="' + itemId + '">');
                f.append('<input type="hidden" name="plugin_sprint_sprints_id" value="' + sprintId + '">');
                f.append('<input type="hidden" name="carry_over_to_sprint" value="1">');
                f.append('<input type="hidden" name="_redirect" value="{{ meeting_url }}">');
                f.append('<input type="hidden" name="_glpi_csrf_token" value="' + $('input[name=_glpi_csrf_token]').first().val() + '">');
                $('body').append(f);
                f.submit();
            });

            // === Quick-edit modal ===
            var $modal = $('#sprint-quickedit-modal').detach().appendTo('body');

            $(document).on('click', '.sprint-quick-edit-btn', function() {
                var $row       = $(this).closest('tr');
                var itemId     = $row.data('item-id');
                var itemName   = $row.data('item-name') || '';
                var status     = $row.data('item-status') || '';
                var priority   = $row.data('item-priority') || 3;
                var usersId    = $row.data('users-id') || 0;
                var points     = $row.data('story-points') || 0;
                var capacity   = $row.data('capacity') || 0;
                var note       = $row.data('note') || '';
                var isFastlane = parseInt($row.data('is-fastlane'), 10) === 1;

                $modal.find('.sprint-qe-title').text(itemName);
                $modal.find('input[name=id]').val(itemId);
                $modal.find('input[name=name]').val(itemName);
                $modal.find('select[name=status]').val(String(status));
                $modal.find('select[name=priority]').val(String(priority));
                $modal.find('select[name=users_id]').val(String(usersId));
                $modal.find('input[name=story_points]').val(points);
                $modal.find('select[name=capacity]').val(String(capacity));
                $modal.find('textarea[name=note]').val(note);
                $modal.find('select[name=carry_over_to_sprint_id]').val('0');
                $modal.find('.sprint-qe-error').hide().text('');
                $modal.find('.sprint-qe-story-points, .sprint-qe-capacity').toggle(!isFastlane);

                // Fastlane items have multi-member allocations via the
                // SprintFastlaneMember junction; the single users_id
                // dropdown isn't authoritative. Hide the owner select for
                // those rows and surface the per-user allocations + a
                // shortcut to the manage tab instead.
                var $owner    = $modal.find('.sprint-qe-owner');
                var $fastList = $modal.find('.sprint-qe-fastlane-allocations');
                if (isFastlane) {
                    $owner.hide();
                    $fastList.show();
                    var allocs = [];
                    var raw = $row.attr('data-fastlane-allocations');
                    if (raw) {
                        try { allocs = JSON.parse(raw); } catch (e) { allocs = []; }
                    }
                    var $list = $fastList.find('.sprint-qe-fastlane-list').empty();
                    if (allocs.length === 0) {
                        $list.append(
                            $('<span class="text-muted fst-italic"></span>').text('{{ __('No allocations', 'sprint')|e('js') }}')
                        );
                    } else {
                        var total = 0;
                        allocs.forEach(function(a) {
                            total += parseInt(a.capacity, 10) || 0;
                            $list.append(
                                $('<div></div>').css({display: 'flex', justifyContent: 'space-between', padding: '2px 0'})
                                    .append($('<span></span>').html('<i class="fas fa-bolt text-warning me-1" style="font-size:0.78em;"></i>').append(document.createTextNode(a.name || '')))
                                    .append($('<strong></strong>').css('color', '#fd7e14').text((a.capacity || 0) + '%'))
                            );
                        });
                        $list.append(
                            $('<div class="text-muted small mt-1" style="border-top:1px dashed #fd7e14;padding-top:4px;"></div>')
                                .append(document.createTextNode('{{ __('Total', 'sprint')|e('js') }}: '))
                                .append($('<strong></strong>').css('color', '#fd7e14').text(total + '%'))
                        );
                    }
                    var fastUrl = $row.attr('data-fastlane-url') || '';
                    if (fastUrl) {
                        $fastList.find('.sprint-qe-fastlane-manage').attr('href', fastUrl);
                    }
                } else {
                    $owner.show();
                    $fastList.hide();
                }

                var capacityLocked = {{ capacity_locked ? 'true' : 'false' }};
                $modal.find('select[name=capacity]').prop('disabled', capacityLocked && !isFastlane);

                var m = new bootstrap.Modal($modal[0]);
                m.show();
                $modal.data('bs-instance', m);
            });

            $(document).on('click', '.sprint-qe-save', function() {
                var $btn = $(this);
                var id = $modal.find('input[name=id]').val();

                $btn.prop('disabled', true);
                $modal.find('.sprint-qe-error').hide().text('');

                $.ajax({
                    url: CFG_GLPI.root_doc + '/plugins/sprint/ajax/csrftoken.php',
                    type: 'GET', dataType: 'json', cache: false
                }).then(function(tokResp) {
                    return $.ajax({
                        url: CFG_GLPI.root_doc + '/plugins/sprint/ajax/updateitemquick.php',
                        type: 'POST', dataType: 'json',
                        data: {
                            id:           id,
                            name:         $modal.find('input[name=name]').val(),
                            status:       $modal.find('select[name=status]').val(),
                            priority:     $modal.find('select[name=priority]').val(),
                            users_id:     $modal.find('select[name=users_id]').val(),
                            story_points: $modal.find('input[name=story_points]').val(),
                            capacity:     $modal.find('select[name=capacity]').val(),
                            note:         $modal.find('textarea[name=note]').val(),
                            carry_over_to_sprint_id: $modal.find('select[name=carry_over_to_sprint_id]').val(),
                            _glpi_csrf_token: tokResp && tokResp.token ? tokResp.token : ''
                        }
                    });
                }).done(function(resp) {
                    if (resp && resp.success) {
                        if (resp.carried_over && resp.carry_over_message) {
                            try { if (typeof glpi_toast_info === 'function') { glpi_toast_info(resp.carry_over_message); } } catch (e) {}
                        }
                        var $row = $('tr.sprint-review-row[data-item-id="' + id + '"]');
                        var statusSelect = $modal.find('select[name=status]');
                        var statusLabel  = statusSelect.find('option:selected').text() || '';
                        var ownerSelect  = $modal.find('select[name=users_id]');
                        var ownerLabel   = ownerSelect.find('option:selected').text() || '';
                        var statusColor  = statusColors[resp.status] || '#6c757d';

                        $row.attr('data-item-name', resp.name).data('item-name', resp.name);
                        $row.attr('data-item-status', resp.status).data('item-status', resp.status);
                        $row.attr('data-item-status-label', statusLabel).data('item-status-label', statusLabel);
                        $row.attr('data-item-priority', resp.priority).data('item-priority', resp.priority);
                        $row.attr('data-users-id', resp.users_id).data('users-id', resp.users_id);
                        $row.attr('data-owner-name', ownerLabel).data('owner-name', ownerLabel);
                        $row.attr('data-story-points', resp.story_points).data('story-points', resp.story_points);
                        $row.attr('data-capacity', resp.capacity).data('capacity', resp.capacity);
                        $row.attr('data-note', resp.note).data('note', resp.note);

                        $row.find('.sprint-review-status')
                            .text(statusLabel)
                            .css('background-color', statusColor);
                        var $ownerCell = $row.find('.sprint-review-owner');
                        if (parseInt(resp.users_id, 10) > 0 && ownerLabel) {
                            $ownerCell.html('<i class="fas fa-user text-muted me-1"></i>' + $('<div>').text(ownerLabel).html());
                        } else {
                            $ownerCell.html('<span class="text-muted fst-italic">{{ __('Unassigned', 'sprint') }}</span>');
                        }
                        $row.find('.sprint-note-display').text(resp.note || '');

                        $row.find('td a').filter(function() {
                            return $(this).attr('href') && $(this).attr('href').indexOf('sprintitem.form.php') !== -1;
                        }).text(resp.name);

                        if (window.SprintFilter) { window.SprintFilter.applyAll(); }

                        var m = $modal.data('bs-instance');
                        if (m) { m.hide(); }
                    } else {
                        $modal.find('.sprint-qe-error').text(resp && resp.message ? resp.message : 'Save failed').show();
                    }
                }).fail(function() {
                    $modal.find('.sprint-qe-error').text('Network error').show();
                }).always(function() {
                    $btn.prop('disabled', false);
                });
            });
        });
        </script>

        {# Quick-edit modal — rendered once, moved out of the form by JS #}
        <div class="modal fade" id="sprint-quickedit-modal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">
                            <i class="fas fa-pen me-1"></i>
                            {{ __('Quick edit', 'sprint') }}: <span class="sprint-qe-title"></span>
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="alert alert-danger sprint-qe-error" style="display:none;white-space:pre-line;"></div>
                        <input type="hidden" name="id" value="">

                        <div class="mb-3">
                            <label class="form-label">{{ __('Name') }}</label>
                            <input type="text" name="name" class="form-control" value="">
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">{{ __('Status') }}</label>
                                <select name="status" class="form-select">
                                    {% for key, label in item_statuses %}
                                    <option value="{{ key }}">{{ label }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">{{ __('Priority') }}</label>
                                <select name="priority" class="form-select">
                                    {% for key, label in item_priorities %}
                                    <option value="{{ key }}">{{ label }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6 mb-3 sprint-qe-owner">
                                <label class="form-label">{{ __('Owner', 'sprint') }}</label>
                                <select name="users_id" class="form-select">
                                    {% for uid, uname in member_options %}
                                    <option value="{{ uid }}">{{ uname }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="col-md-6 mb-3 sprint-qe-fastlane-allocations" style="display:none;">
                                <label class="form-label">
                                    <i class="fas fa-bolt text-warning me-1"></i>{{ __('Fastlane allocations', 'sprint') }}
                                </label>
                                <div class="sprint-qe-fastlane-list" style="border:1px solid #e9ecef;border-radius:6px;padding:8px 10px;background:#fff8e1;font-size:0.9em;min-height:38px;"></div>
                                <a href="#" class="sprint-qe-fastlane-manage btn btn-sm btn-outline-warning mt-2" target="_blank" rel="noopener">
                                    <i class="fas fa-cog me-1"></i>{{ __('Manage fastlane members', 'sprint') }}
                                </a>
                            </div>
                            <div class="col-md-3 mb-3 sprint-qe-story-points">
                                <label class="form-label">{{ __('Story Points', 'sprint') }}</label>
                                <input type="number" name="story_points" class="form-control" min="0" step="1" value="0">
                            </div>
                            <div class="col-md-3 mb-3 sprint-qe-capacity">
                                <label class="form-label">{{ __('Capacity (%)', 'sprint') }}</label>
                                <select name="capacity" class="form-select">
                                    {% for val, label in capacity_choices %}
                                    <option value="{{ val }}">{{ label }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">{{ __('Note', 'sprint') }}</label>
                            <textarea name="note" class="form-control" rows="8" style="min-height:180px;"></textarea>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">
                                <i class="fas fa-forward text-success me-1"></i>{{ __('Carry over to sprint', 'sprint') }}
                            </label>
                            <select name="carry_over_to_sprint_id" class="form-select">
                                <option value="0">— {{ __('Do not carry over', 'sprint') }} —</option>
                                {% for target_id, target_label in move_target_sprints %}
                                <option value="{{ target_id }}">{{ target_label }}</option>
                                {% endfor %}
                            </select>
                            <div class="form-text small text-muted">
                                {{ __('A fresh copy is created in the target sprint. The original stays in this sprint.', 'sprint') }}
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ __('Cancel') }}</button>
                        <button type="button" class="btn btn-primary sprint-qe-save">
                            <i class="fas fa-save me-1"></i> {{ __('Save') }}
                        </button>
                    </div>
                </div>
            </div>
        </div>

    </td></tr>
    {% endif %}

{% endblock %}
